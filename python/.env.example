# Local paths for the rc2-glm CLI. Copy to python/.env and edit.
# All entries are optional; CLI flags override anything set here.

# Directory containing formatted v7.3 .mat files.
# When set, `rc2-glm` without a `mat` argument will pick the first
# *.mat in this directory. A bare filename (no slashes) is also
# resolved against this directory.
RC2_FORMATTED_DATA_DIR=/path/to/motion_clouds/formatted_data

# Alternatively pin a single file (takes precedence over DIR).
# RC2_FORMATTED_DATA_PATH=/path/to/motion_clouds/formatted_data/probe01.mat

# Motion-cloud stimulus lookup. Set both for V/VT stimulus params to
# populate in the design matrix.
RC2_MC_SEQUENCE_PATH=/path/to/motion_clouds/motion_cloud_sequence_250414.mat
RC2_MC_FOLDERS_PATH=/path/to/motion_clouds/image_folders.mat

# Default output directory for CSVs. `out_dir` CLI arg overrides.
RC2_GLM_OUTPUT_DIR=/path/to/motion_clouds/figures/glm_out
